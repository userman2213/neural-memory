<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neural Memory — Knowledge Graph</title>
__PLOTLY_SCRIPT__
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap');

  :root {
    --bg: #050510;
    --surface: rgba(12, 15, 30, 0.85);
    --surface2: rgba(18, 22, 45, 0.7);
    --border: rgba(100, 120, 255, 0.12);
    --border-glow: rgba(100, 140, 255, 0.25);
    --text: #b8c4e0;
    --text-bright: #e8edf8;
    --text-dim: #5a6480;
    --neural-purple: #a855f7;
    --neural-blue: #3b82f6;
    --neural-cyan: #06b6d4;
    --neural-green: #10b981;
    --neural-pink: #ec4899;
    --neural-orange: #f59e0b;
    --glow-purple: rgba(168, 85, 247, 0.4);
    --glow-blue: rgba(59, 130, 246, 0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── Particle canvas ── */
  #particles {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 0; pointer-events: none;
  }

  /* ── Scanline overlay ── */
  body::after {
    content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px
    );
    pointer-events: none; z-index: 999;
  }

  /* ── Header ── */
  .header {
    position: relative; z-index: 1;
    text-align: center; padding: 40px 20px 32px;
    background: linear-gradient(180deg, rgba(168,85,247,0.08) 0%, transparent 100%);
    border-bottom: 1px solid var(--border);
  }
  .header::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--neural-purple), transparent);
  }
  .header h1 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 32px; font-weight: 700; color: var(--text-bright);
    letter-spacing: -0.5px;
  }
  .header h1 .glow {
    background: linear-gradient(135deg, var(--neural-purple), var(--neural-cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 0 40px var(--glow-purple);
  }
  .header .tagline {
    font-size: 13px; color: var(--text-dim); margin-top: 6px;
    font-family: 'JetBrains Mono', monospace;
  }
  .header .source {
    font-size: 11px; color: var(--text-dim); margin-top: 4px;
    font-family: 'JetBrains Mono', monospace; opacity: 0.7;
  }

  /* ── Stats bar ── */
  .stats {
    display: flex; justify-content: center; gap: 48px; margin-top: 24px;
    flex-wrap: wrap;
  }
  .stat { text-align: center; position: relative; }
  .stat::after {
    content: ''; position: absolute; bottom: -8px; left: 50%; transform: translateX(-50%);
    width: 24px; height: 2px;
    background: linear-gradient(90deg, var(--neural-purple), var(--neural-cyan));
    border-radius: 1px; opacity: 0.5;
  }
  .stat .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 36px; font-weight: 700;
    background: linear-gradient(135deg, var(--neural-purple), var(--neural-blue));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat .lbl {
    font-size: 10px; color: var(--text-dim);
    text-transform: uppercase; letter-spacing: 2px; margin-top: 4px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ── Grid ── */
  .grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; padding: 20px; max-width: 1600px; margin: 0 auto;
  }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

  /* ── Cards — glassmorphism ── */
  .card {
    background: var(--surface);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .card:hover {
    border-color: var(--border-glow);
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.06), inset 0 0 30px rgba(168, 85, 247, 0.02);
  }
  .card.wide { grid-column: 1 / -1; }
  .card-title {
    padding: 14px 18px; font-size: 12px; font-weight: 600;
    color: var(--text-bright); border-bottom: 1px solid var(--border);
    background: var(--surface2);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px; text-transform: uppercase;
    display: flex; align-items: center; gap: 8px;
  }
  .card-title .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--neural-purple);
    box-shadow: 0 0 8px var(--glow-purple);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .plot { width: 100%; min-height: 320px; }

  /* ── Activity feed ── */
  .activity-section {
    position: relative; z-index: 1;
    max-width: 1600px; margin: 0 auto; padding: 0 20px 20px;
  }
  .activity-card {
    background: var(--surface);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden;
  }
  .activity-list {
    max-height: 300px; overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(168,85,247,0.3) transparent;
  }
  .activity-item {
    padding: 10px 18px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
    font-size: 12px; font-family: 'JetBrains Mono', monospace;
    transition: background 0.2s;
  }
  .activity-item:hover { background: rgba(168, 85, 247, 0.04); }
  .activity-item .node-id {
    color: var(--neural-cyan); min-width: 50px;
  }
  .activity-item .node-label {
    color: var(--text-bright); flex: 1;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .activity-item .degree-badge {
    padding: 2px 8px; border-radius: 10px; font-size: 10px;
    font-weight: 600;
  }
  .degree-high { background: rgba(168,85,247,0.2); color: var(--neural-purple); }
  .degree-med { background: rgba(59,130,246,0.2); color: var(--neural-blue); }
  .degree-low { background: rgba(100,120,180,0.15); color: var(--text-dim); }

  /* ── Footer ── */
  .footer {
    position: relative; z-index: 1;
    text-align: center; padding: 20px; font-size: 11px; color: var(--text-dim);
    border-top: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
  }
  .footer a {
    color: var(--neural-purple); text-decoration: none;
    transition: color 0.2s;
  }
  .footer a:hover { color: var(--neural-cyan); }
  .footer .version {
    display: inline-block; padding: 2px 8px;
    background: rgba(168,85,247,0.1); border-radius: 8px;
    margin-left: 8px; font-size: 10px;
  }

  /* ── Animations ── */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .card, .activity-card {
    animation: fadeSlideUp 0.6s ease-out backwards;
  }
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
  .card:nth-child(5) { animation-delay: 0.25s; }
  .activity-card { animation-delay: 0.3s; }

  /* ── Number counter animation ── */
  .stat .num { transition: all 0.3s; }
</style>
</head>
<body>

<canvas id="particles"></canvas>

<div class="header">
  <h1>NEURAL <span class="glow">MEMORY</span></h1>
  <div class="tagline">// knowledge graph visualization</div>
  <div class="source" id="source_info"></div>
  <div class="stats">
    <div class="stat"><div class="num" id="s_mem">—</div><div class="lbl">Memories</div></div>
    <div class="stat"><div class="num" id="s_conn">—</div><div class="lbl">Connections</div></div>
    <div class="stat"><div class="num" id="s_dim">—</div><div class="lbl">Embed Dim</div></div>
    <div class="stat"><div class="num" id="s_deg">—</div><div class="lbl">Avg Degree</div></div>
    <div class="stat"><div class="num" id="s_density">—</div><div class="lbl">Density %</div></div>
  </div>
</div>

<div class="grid">
  <div class="card">
    <div class="card-title"><span class="dot"></span> Memory Categories</div>
    <div id="pie_categories" class="plot"></div>
  </div>
  <div class="card">
    <div class="card-title"><span class="dot"></span> Connection Strength</div>
    <div id="bar_weights" class="plot"></div>
  </div>

  <div class="card wide">
    <div class="card-title"><span class="dot"></span> Knowledge Graph — Top Hub Nodes</div>
    <div id="network" class="plot" style="min-height:500px"></div>
  </div>

  <div class="card">
    <div class="card-title"><span class="dot"></span> Degree vs Avg Weight</div>
    <div id="scatter_degree" class="plot"></div>
  </div>
  <div class="card">
    <div class="card-title"><span class="dot"></span> Category Flow Matrix</div>
    <div id="heatmap" class="plot"></div>
  </div>

  <div class="card">
    <div class="card-title"><span class="dot"></span> Salience Distribution</div>
    <div id="hist_salience" class="plot"></div>
  </div>
  <div class="card">
    <div class="card-title"><span class="dot"></span> Access Frequency</div>
    <div id="bar_access" class="plot"></div>
  </div>
</div>

<div class="activity-section">
  <div class="activity-card">
    <div class="card-title"><span class="dot"></span> Top Hub Nodes</div>
    <div class="activity-list" id="activity_list"></div>
  </div>
</div>

<div class="footer">
  Neural Memory Adapter &bull; <a href="https://github.com/nicekate/neural-memory-adapter">GitHub</a>
  &bull; <span id="gen_time"></span>
  <span class="version">v2.0</span>
</div>

<script>
const D = __DATA_JSON__;

// ═══════════════════════════════════════════
// Particle system — live neural network bg
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('particles');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [], mouse = { x: -1000, y: -1000 };

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  document.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });

  const N = Math.min(80, Math.max(30, Math.floor(W * H / 20000)));
  for (let i = 0; i < N; i++) {
    particles.push({
      x: Math.random() * W, y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.3, vy: (Math.random() - 0.5) * 0.3,
      r: Math.random() * 1.5 + 0.5,
      hue: 260 + Math.random() * 40,
    });
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d < 150) {
          const alpha = (1 - d / 150) * 0.15;
          ctx.beginPath();
          ctx.strokeStyle = `hsla(265, 70%, 65%, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    // Mouse connections
    particles.forEach(p => {
      const dx = p.x - mouse.x, dy = p.y - mouse.y;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < 200) {
        const alpha = (1 - d / 200) * 0.3;
        ctx.beginPath();
        ctx.strokeStyle = `hsla(185, 90%, 60%, ${alpha})`;
        ctx.lineWidth = 0.8;
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(mouse.x, mouse.y);
        ctx.stroke();
      }
    });

    // Particles
    particles.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${p.hue}, 70%, 70%, 0.6)`;
      ctx.fill();

      // Glow
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${p.hue}, 70%, 70%, 0.08)`;
      ctx.fill();

      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
    });

    requestAnimationFrame(draw);
  }
  draw();
})();

// ═══════════════════════════════════════════
// Plotly config
// ═══════════════════════════════════════════
const cc = {
  'Conversation': '#a855f7', 'Peer': '#10b981', 'Session': '#f59e0b',
  'Document': '#3b82f6', 'Skill': '#ec4899', 'Other': '#5a6480',
};
const ccGlow = {
  'Conversation': 'rgba(168,85,247,0.5)', 'Peer': 'rgba(16,185,129,0.5)',
  'Session': 'rgba(245,158,11,0.5)', 'Document': 'rgba(59,130,246,0.5)',
  'Skill': 'rgba(236,72,153,0.5)', 'Other': 'rgba(90,100,128,0.3)',
};

const plotLayout = {
  paper_bgcolor: 'rgba(0,0,0,0)',
  plot_bgcolor: 'rgba(0,0,0,0)',
  font: { color: '#b8c4e0', family: 'Inter, system-ui', size: 11 },
  margin: { t: 20, r: 16, b: 36, l: 48 },
  xaxis: { gridcolor: 'rgba(100,120,255,0.06)', zerolinecolor: 'rgba(100,120,255,0.1)', linecolor: 'rgba(100,120,255,0.1)' },
  yaxis: { gridcolor: 'rgba(100,120,255,0.06)', zerolinecolor: 'rgba(100,120,255,0.1)', linecolor: 'rgba(100,120,255,0.1)' },
};
const plotConfig = { responsive: true, displayModeBar: false };

// ═══════════════════════════════════════════
// Header stats with animation
// ═══════════════════════════════════════════
function animateNum(id, target) {
  const el = document.getElementById(id);
  const start = 0; const duration = 1200;
  const t0 = performance.now();
  function tick(now) {
    const p = Math.min((now - t0) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(start + (target - start) * ease).toLocaleString();
    if (p < 1) requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
}

animateNum('s_mem', D.stats.memories);
animateNum('s_conn', D.stats.connections);
document.getElementById('s_dim').textContent = D.stats.embedding_dim;
const avgDeg = D.nodes.length ? Math.round(D.nodes.reduce((s,n) => s + n.total_degree, 0) / D.nodes.length) : 0;
animateNum('s_deg', avgDeg);
const maxPossible = D.nodes.length * (D.nodes.length - 1);
const density = maxPossible > 0 ? ((D.stats.connections / maxPossible) * 100).toFixed(1) : '0.0';
document.getElementById('s_density').textContent = density;
document.getElementById('source_info').textContent = `${D.stats.source} :: ${D.stats.path}`;
document.getElementById('gen_time').textContent = new Date().toLocaleString();

// ═══════════════════════════════════════════
// 1. Category Donut — with glow
// ═══════════════════════════════════════════
Plotly.newPlot('pie_categories', [{
  type: 'pie', hole: 0.55,
  labels: D.categories.map(c => c.name),
  values: D.categories.map(c => c.count),
  marker: {
    colors: D.categories.map(c => cc[c.name] || '#5a6480'),
    line: { color: '#050510', width: 2 },
  },
  textinfo: 'label+percent',
  textfont: { color: '#e8edf8', size: 11, family: 'JetBrains Mono' },
  hovertemplate: '<b>%{label}</b><br>%{value} memories<br>%{percent}<extra></extra>',
  pull: D.categories.map((_, i) => i === 0 ? 0.04 : 0),
}], {
  ...plotLayout, showlegend: false,
  margin: { t: 8, b: 8, l: 8, r: 8 },
  annotations: [{
    text: `<b>${D.stats.memories}</b><br>total`,
    showarrow: false, font: { size: 16, color: '#e8edf8', family: 'JetBrains Mono' },
    x: 0.5, y: 0.5,
  }],
}, plotConfig);

// ═══════════════════════════════════════════
// 2. Weight Bar — gradient
// ═══════════════════════════════════════════
const wOrder = ['Very Weak (0-0.2)', 'Weak (0.2-0.4)', 'Medium (0.4-0.6)', 'Med-Strong (0.6-0.8)', 'Strong (0.8-1.0)'];
const wColors = ['rgba(90,100,128,0.4)', 'rgba(90,100,128,0.6)', '#3b82f6', '#a855f7', '#10b981'];
const sW = wOrder.map(w => D.weights.find(x => x.bucket === w) || { bucket: w, count: 0 });
Plotly.newPlot('bar_weights', [{
  type: 'bar',
  x: sW.map(w => w.bucket.replace(/ \(.*/, '')),
  y: sW.map(w => w.count),
  marker: {
    color: wColors,
    line: { color: 'rgba(100,120,255,0.2)', width: 1 },
  },
  text: sW.map(w => w.count.toLocaleString()),
  textposition: 'outside',
  textfont: { color: '#8b949e', size: 10, family: 'JetBrains Mono' },
  hovertemplate: '<b>%{x}</b><br>%{y:,} connections<extra></extra>',
}], {
  ...plotLayout,
  yaxis: { ...plotLayout.yaxis, title: { text: 'Connections', font: { size: 10 } } },
  margin: { ...plotLayout.margin, b: 60 },
}, plotConfig);

// ═══════════════════════════════════════════
// 3. Network Graph — force-directed style
// ═══════════════════════════════════════════
const nMap = {}; D.nodes.forEach((n, i) => nMap[n.id] = i);
const pos = {};

// Better layout: cluster by category + force hint
const catCenters = {};
const cats = [...new Set(D.nodes.map(n => n.category))];
const catAngle = {};
cats.forEach((c, i) => { catAngle[c] = (i / cats.length) * 2 * Math.PI; });

D.nodes.forEach((n, i) => {
  const baseAngle = catAngle[n.category] || 0;
  const spread = 0.8;
  const a = baseAngle + (Math.random() - 0.5) * spread;
  const r = 120 + Math.sqrt(n.total_degree) * 18 + Math.random() * 40;
  pos[n.id] = { x: r * Math.cos(a), y: r * Math.sin(a) };
});

const eX = [], eY = [], eAlpha = [];
D.edges.forEach(e => {
  if (pos[e.source] && pos[e.target]) {
    eX.push(pos[e.source].x, pos[e.target].x, null);
    eY.push(pos[e.source].y, pos[e.target].y, null);
  }
});

const byCat = {};
D.nodes.forEach(n => {
  if (!byCat[n.category]) byCat[n.category] = { x: [], y: [], t: [], s: [], ids: [] };
  const b = byCat[n.category];
  b.x.push(pos[n.id].x); b.y.push(pos[n.id].y);
  b.t.push(`<b>${n.label}</b><br>Deg: ${n.total_degree} | W: ${n.avg_weight}<br>Salience: ${n.salience.toFixed(2)}`);
  b.s.push(Math.max(6, Math.sqrt(n.total_degree) * 3.5));
  b.ids.push(n.id);
});

const traces = [{
  type: 'scatter', mode: 'lines', x: eX, y: eY,
  line: { color: 'rgba(100,120,255,0.08)', width: 0.5 },
  hoverinfo: 'skip',
}];
Object.entries(byCat).forEach(([cat, b]) => {
  traces.push({
    type: 'scatter', mode: 'markers', name: cat,
    x: b.x, y: b.y,
    marker: {
      size: b.s,
      color: cc[cat] || '#5a6480',
      opacity: 0.9,
      line: { width: 1.5, color: 'rgba(5,5,16,0.8)' },
    },
    text: b.t,
    hovertemplate: '%{text}<extra>' + cat + '</extra>',
  });
});
Plotly.newPlot('network', traces, {
  ...plotLayout,
  showlegend: true,
  legend: {
    font: { size: 10, family: 'JetBrains Mono' },
    x: 0.01, y: 0.99,
    bgcolor: 'rgba(5,5,16,0.7)',
    bordercolor: 'rgba(100,120,255,0.15)',
    borderwidth: 1,
  },
  xaxis: { showgrid: false, showticklabels: false, zeroline: false, showline: false },
  yaxis: { showgrid: false, showticklabels: false, zeroline: false, showline: false, scaleanchor: 'x' },
  margin: { t: 8, b: 8, l: 8, r: 8 },
  hovermode: 'closest',
}, plotConfig);

// ═══════════════════════════════════════════
// 4. Scatter: Degree vs Weight
// ═══════════════════════════════════════════
Plotly.newPlot('scatter_degree', [{
  type: 'scatter', mode: 'markers',
  x: D.nodes.map(n => n.total_degree),
  y: D.nodes.map(n => n.avg_weight),
  marker: {
    size: D.nodes.map(n => Math.max(5, Math.sqrt(n.total_degree) * 2.5)),
    color: D.nodes.map(n => cc[n.category] || '#5a6480'),
    opacity: 0.75,
    line: { width: 0.5, color: 'rgba(100,120,255,0.15)' },
  },
  text: D.nodes.map(n => `<b>${n.label}</b><br>Deg: ${n.total_degree} | W: ${n.avg_weight}`),
  hovertemplate: '%{text}<extra></extra>',
}], {
  ...plotLayout,
  xaxis: { ...plotLayout.xaxis, title: { text: 'Total Degree', font: { size: 10 } } },
  yaxis: { ...plotLayout.yaxis, title: { text: 'Avg Connection Weight', font: { size: 10 } } },
}, plotConfig);

// ═══════════════════════════════════════════
// 5. Heatmap — category flow
// ═══════════════════════════════════════════
const mat = cats.map(() => cats.map(() => 0));
D.edges.forEach(e => {
  const sn = D.nodes.find(n => n.id === e.source);
  const tn = D.nodes.find(n => n.id === e.target);
  if (sn && tn) {
    const si = cats.indexOf(sn.category), ti = cats.indexOf(tn.category);
    if (si >= 0 && ti >= 0) mat[si][ti]++;
  }
});
Plotly.newPlot('heatmap', [{
  type: 'heatmap', z: mat, x: cats, y: cats,
  colorscale: [
    [0, 'rgba(5,5,16,1)'],
    [0.2, 'rgba(30,20,80,1)'],
    [0.5, 'rgba(59,130,246,1)'],
    [0.8, 'rgba(168,85,247,1)'],
    [1, 'rgba(236,72,153,1)'],
  ],
  text: mat.map(r => r.map(v => v || '')),
  texttemplate: '%{text}',
  textfont: { size: 10, family: 'JetBrains Mono' },
  hovertemplate: '<b>%{y} → %{x}</b><br>%{z} connections<extra></extra>',
  showscale: false,
}], {
  ...plotLayout,
  margin: { ...plotLayout.margin, b: 60, l: 90 },
}, plotConfig);

// ═══════════════════════════════════════════
// 6. Salience histogram (NEW)
// ═══════════════════════════════════════════
Plotly.newPlot('hist_salience', [{
  type: 'histogram',
  x: D.nodes.map(n => n.salience),
  nbinsx: 30,
  marker: {
    color: 'rgba(168,85,247,0.5)',
    line: { color: 'rgba(168,85,247,0.8)', width: 1 },
  },
  hovertemplate: 'Salience: %{x:.2f}<br>Count: %{y}<extra></extra>',
}], {
  ...plotLayout,
  xaxis: { ...plotLayout.xaxis, title: { text: 'Salience', font: { size: 10 } } },
  yaxis: { ...plotLayout.yaxis, title: { text: 'Memories', font: { size: 10 } } },
}, plotConfig);

// ═══════════════════════════════════════════
// 7. Access frequency (NEW)
// ═══════════════════════════════════════════
const accessBuckets = [
  { label: '0', min: 0, max: 0 },
  { label: '1-5', min: 1, max: 5 },
  { label: '6-20', min: 6, max: 20 },
  { label: '21-50', min: 21, max: 50 },
  { label: '50+', min: 51, max: Infinity },
];
const accessCounts = accessBuckets.map(b =>
  D.nodes.filter(n => n.access_count >= b.min && n.access_count <= b.max).length
);
Plotly.newPlot('bar_access', [{
  type: 'bar',
  x: accessBuckets.map(b => b.label),
  y: accessCounts,
  marker: {
    color: ['rgba(90,100,128,0.3)', '#3b82f6', '#06b6d4', '#a855f7', '#ec4899'],
    line: { color: 'rgba(100,120,255,0.2)', width: 1 },
  },
  text: accessCounts.map(c => c.toLocaleString()),
  textposition: 'outside',
  textfont: { color: '#8b949e', size: 10, family: 'JetBrains Mono' },
  hovertemplate: '<b>%{x} accesses</b><br>%{y} memories<extra></extra>',
}], {
  ...plotLayout,
  xaxis: { ...plotLayout.xaxis, title: { text: 'Access Count', font: { size: 10 } } },
  yaxis: { ...plotLayout.yaxis, title: { text: 'Memories', font: { size: 10 } } },
}, plotConfig);

// ═══════════════════════════════════════════
// 8. Activity feed — top hub nodes
// ═══════════════════════════════════════════
const topNodes = D.nodes.slice(0, 50);
const list = document.getElementById('activity_list');
topNodes.forEach(n => {
  const div = document.createElement('div');
  div.className = 'activity-item';
  const degClass = n.total_degree > 50 ? 'degree-high' : n.total_degree > 20 ? 'degree-med' : 'degree-low';
  div.innerHTML = `
    <span class="node-id">#${n.id}</span>
    <span class="node-label">${n.label}</span>
    <span class="degree-badge ${degClass}">${n.total_degree}°</span>
  `;
  list.appendChild(div);
});
</script>
</body>
</html>
